{
  "title": "SentiSOC Security Dashboard",
  "uid": "sentisoc-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "tags": ["sentisoc", "security"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Login Attempts",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "auth_login_attempts_total",
        "legendFormat": "{{result}}"
      }],
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 2, "type": "stat", "title": "Failed Logins (last 5m)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "increase(auth_login_attempts_total{result=\"failure\"}[5m])",
        "legendFormat": "failed"
      }],
      "options": {"colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 3, "type": "stat", "title": "Registered Users",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "auth_registered_users_total", "legendFormat": "users"}],
      "options": {"colorMode": "background"}
    },
    {
      "id": 4, "type": "stat", "title": "Active Reservations",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "reservations_total{status=\"active\"}", "legendFormat": "active"}],
      "options": {"colorMode": "background"}
    },
    {
      "id": 5, "type": "timeseries", "title": "Login Attempts Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(auth_login_attempts_total{result=\"success\"}[1m])", "legendFormat": "success/s"},
        {"expr": "rate(auth_login_attempts_total{result=\"failure\"}[1m])", "legendFormat": "failure/s"}
      ]
    },
    {
      "id": 6, "type": "gauge", "title": "Host CPU",
      "gridPos": {"h": 8, "w": 4, "x": 12, "y": 4},
      "targets": [{
        "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", 
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {"steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 50},
            {"color": "red", "value": 80}
          ]}
        }
      }
    },
    {
      "id": 8, "type": "gauge", "title": "Host RAM",
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 4},
      "targets": [{
        "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)", 
        "legendFormat": "RAM %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {"steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 75},
            {"color": "red", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 9, "type": "gauge", "title": "Host Disk",
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 4},
      "targets": [{
        "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/rootfs\"}) * 100)", 
        "legendFormat": "Disk %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {"steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 80},
            {"color": "red", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 7, 
      "type": "logs", 
      "title": "Live Security & System Logs (Loki)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12},
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{container=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}